},
"speaker": "O_GARDE",
"exit": true,
"voice": {
"en": [
{},
{},
{},
{}
]
}
}
],
"text": {
"en": "Deux donuts."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"never_hide": true
},
{
"id": 11,
"choice": true,
"sentences": [
{
"id": 14,
"sentences": [
{
"id": 18,
"choice": true,
"sentences": [
{
"id": 20,
"sentences": [
{
"id": 21,
"text": {
"en": "Les gardes mangent en męme temps que vous, dans une autre salle."
