"dialogs": [
{
"sid": 11,
"uid": "D_GARDE",
"content": {
"sentence": {
"sentences": [
{
"id": 1,
"choice": true,
"text": {
"en": "Comment ça va?"
},
"sentences": [
{
"id": 4,
"text": {
"en": "Bien, merci."
},
"speaker": "O_GARDE",
"exit": true,
"voice": {
"en": [
{},
{},
{},
{}
]
}
}
],
"voice": {
