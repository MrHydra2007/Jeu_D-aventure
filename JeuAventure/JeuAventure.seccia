{}
]
},
"never_hide": true
},
{
"id": 2,
"choice": true,
"sentences": [
{
"id": 5,
"sentences": [
{
"id": 6,
"sentences": [
{
"id": 7,
"text": {
"en": "Il fallais y penser avant de tuer une grand mčre."
},
"speaker": "O_GARDE",
"exit": true,
"voice": {
"en": [
{},
{},
{},
{}
]
}
}
],
"text": {
"en": "Ma mčre est malade, il faut que je l'aide !"
},
"speaker": "O_RONALDINHO",
"voice": {
"en": [
{},
{},
{},
{}
]
}
}
],
"text": {
"en": "Pourquoi?"
},
"speaker": "O_GARDE",
"voice": {
"en": [
{},
{},
{},
{}
]
}
}
],
"text": {
"en": "Il faut que je sorte !"
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"never_hide": true
},
{
"id": 3,
"choice": true,
"sentences": [
{
"id": 8,
"sentences": [
{
"id": 9,
"choice": true,
"sentences": [
{
"id": 12,
"text": {
"en": "Un-becile."
},
"speaker": "O_GARDE",
"exit": true,
"voice": {
"en": [
{},
{},
{},
{}
]
}
}
],
"text": {
"en": "Un donut."
},
"voice": {
"en": [
{},
{},
{},
{}
]
},
"never_hide": true
},
{
"id": 10,
"choice": true,
"sentences": [
{
"id": 13,
"text": {
